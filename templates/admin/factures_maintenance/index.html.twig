{% extends 'base.html.twig' %}

{% block title %}Historique des factures de maintenance{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-file-invoice-dollar"></i> Historique des factures de maintenance</h2>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total des factures</h5>
                    <h3>{{ factures.getTotalItemCount }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Coût total maintenance</h5>
                    <h3>{{ totalCost|number_format(2, '.', ' ') }} TND</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {% if factures|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Numéro</th>
                                <th>Date</th>
                                <th>Véhicule</th>
                                <th>Technicien</th>
                                <th>Montant HT</th>
                                <th>TVA</th>
                                <th>Montant TTC</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for facture in factures %}
                                <tr>
                                    <td><strong>{{ facture.numero }}</strong></td>
                                    <td>{{ facture.dateEmission|date('d/m/Y H:i') }}</td>
                                    <td>
                                        {{ facture.vehicule.marque }} {{ facture.vehicule.modele }}<br>
                                        <small class="text-muted">{{ facture.vehicule.immatriculation }}</small>
                                    </td>
                                    <td>
                                        {% if facture.technician %}
                                            {{ facture.technician.prenom }} {{ facture.technician.nom }}
                                        {% else %}
                                            <span class="text-muted">N/A</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ facture.montantHT|number_format(2, '.', ' ') }} TND</td>
                                    <td>{{ facture.tauxTVA }}%</td>
                                    <td><strong>{{ facture.montantTTC|number_format(2, '.', ' ') }} TND</strong></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('admin_factures_maintenance_show', {id: facture.id}) }}" 
                                               class="btn btn-sm btn-info" title="Voir">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('admin_factures_maintenance_pdf', {id: facture.id}) }}" 
                                               class="btn btn-sm btn-primary" title="PDF" target="_blank">
                                                <i class="fas fa-file-pdf"></i>
                                            </a>
                                            <form method="post" 
                                                  action="{{ path('admin_factures_maintenance_delete', {id: facture.id}) }}" 
                                                  style="display:inline;"
                                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette facture ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_facture_' ~ facture.id) }}">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-center mt-3">
                    {{ knp_pagination_render(factures) }}
                </div>
            {% else %}
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Aucune facture de maintenance enregistrée.
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
