{% extends 'base.html.twig' %}

{% block title %}Mes Livraisons - PackTrack{% endblock %}

{% block stylesheets %}
<style>
    .container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 20px;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .btn {
        padding: 12px 24px;
        background: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
    }
    
    .livraison-table {
        background: white;
        border-radius: 12px;
        overflow-x: auto;       /* ✅ scroll horizontal */
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    table {
        width: 100%;
        min-width: 900px;       /* ✅ empêche les colonnes de trop se rétrécir */
        border-collapse: collapse;
    }
    
    th {
        background: #f8f9fa;
        padding: 12px 10px;     /* ✅ padding réduit */
        text-align: left;
        font-weight: 600;
        font-size: 13px;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;    /* ✅ headers sur une seule ligne */
    }
    
    td {
        padding: 12px 10px;     /* ✅ padding réduit */
        border-bottom: 1px solid #dee2e6;
        font-size: 13px;
        vertical-align: middle;
    }
    
    .badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }
    
    .badge.en_cours {
        background: #d1ecf1;
        color: #0c5460;
    }
    
    .badge.termine {
        background: #d4edda;
        color: #155724;
    }
    
    
    .btn-finish:hover {
        background: #218838;
    }
    .badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }


    .btn-info-icon {
    color: #17a2b8;
    text-decoration: none;
    font-size: 18px;
    margin-right: 10px;
    transition: transform 0.2s;
    display: inline-block;
    }

    .btn-info-icon:hover {
        transform: scale(1.2);
    }
    
    
</style>
{% endblock %}

{% block body %}
<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">✅ {{ message }}</div>
    {% endfor %}

    <div class="page-header">
        <h1>📋 Mes Livraisons</h1>
        <a href="{{ path('app_livraison_index') }}" class="btn">🔍 Voir colis disponibles</a>
    </div>

    <div class="livraison-table">
        <table>
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Colis</th>
                    <th>Destination</th>
                    <th>Poids</th>
                    <th>Date début</th>
                    <th>Distance Estimée</th>
                    <th>Durée Estimée</th>
                    <th>Total</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for livraison in livraisons %}
                <tr>
                    <td>#{{ livraison.id }}</td>
                    <td>#{{ livraison.colis.id }}</td>
                    <td>{{ livraison.colis.adresseDestination|slice(0, 40) }}...</td>
                    <td>{{ livraison.colis.poids ? livraison.colis.poids ~ ' kg' : 'N/A' }}</td>
                    <td>{{ livraison.dateDebut|date('d/m/Y H:i') }}</td>
                    <td>
                        {% if livraison.distanceKm %}
                            <strong>{{ livraison.distanceKm }} km</strong>
                        {% else %}
                            <span style="color: #6c757d;">-</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if livraison.dureeFormatee %}
                            <strong style="color: #007bff;">{{ livraison.dureeFormatee }}</strong>
                        {% else %}
                            <span style="color: #6c757d;">-</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if livraison.total %}
                            <strong style="color: #28a745;">{{ livraison.total|number_format(2, ',', ' ') }} €</strong>
                        {% else %}
                            <span style="color: #6c757d;">-</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge {{ livraison.statut }}">
                            {{ livraison.statut|replace({'_': ' '})|title }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_livraison_details', {id: livraison.id}) }}" 
                        class="btn-info-icon" 
                        title="Voir les détails">
                            ℹ️
                        </a>
                        {% if livraison.statut == 'en_cours' %}
                            <form method="post" action="{{ path('app_livraison_terminer', {id: livraison.id}) }}"
                                onsubmit="return confirm('Confirmer la fin de cette livraison ?')"
                                style="display: inline;">
                                <button type="submit" class="btn-info-icon" title="Terminer la livraison" 
                                        style="background: none; border: none; cursor: pointer;">
                                    ✅
                                </button>
                            </form>
                        {% else %}
                            <span title="Terminée">✓</span>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" style="text-align: center; padding: 40px; color: #6c757d;">
                        Aucune livraison pour le moment.
                    </td>
                </tr>
                {% endfor %}
                </tbody>
        </table>
    </div>
</div>
{% endblock %}